# ── LLM Provider ─────────────────────────────────────────────
# Choose: arcane (uses arcane-agent with underlying provider)
# For direct providers: anthropic | openai (deprecated, use arcane instead)
LLM_PROVIDER=arcane

# ── Arcane Agent (when LLM_PROVIDER=arcane) ──────────────────
# Choose underlying provider: anthropic | openai
ARCANE_LLM_PROVIDER=openai
ARCANE_MODEL=                          # Optional: override underlying model

# ── Anthropic Provider ────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=                    # Optional: custom Anthropic endpoint
ANTHROPIC_MODEL=claude-opus-4-6        # Optional: override default model

# ── OpenAI-Compatible Provider ────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o